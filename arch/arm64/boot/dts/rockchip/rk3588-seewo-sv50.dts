&usb_host1_xhci {
	dr_mode = "host";
	snps,parkmode-disable-ss-quirk;
	status = "okay";
};

&u2phy1 {
	status = "okay";
};

&u2phy1_otg {
	phy-supply = <&vcc5v0_host>;
	status = "okay";
};

